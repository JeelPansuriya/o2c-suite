<?xml version="1.0" encoding="utf-8"?>
<core:FragmentDefinition
    xmlns:core="sap.ui.core"
    xmlns="sap.m">
    <Dialog id="addItemDialog" title="Add Item">
        <content>
            <VBox class="sapUiSmallMargin">
                <Label text="Product"/>
                <Select id="productSelect" items="{ path: '/Products' }">
                    <core:Item key="{productID}" text="{productName}" xmlns:core="sap.ui.core"/>
                </Select>
                <Label text="Quantity"/>
                <Input id="quantityInput" type="Number" value="1"/>
            </VBox>
        </content>
        <beginButton>
            <Button text="Add" press=".onAddItem"/>
        </beginButton>
        <endButton>
            <Button text="Cancel" press=".onCloseDialog"/>
        </endButton>
    </Dialog>
</core:FragmentDefinition>
