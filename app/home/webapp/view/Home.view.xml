<mvc:View
    controllerName="o2c.home.controller.Home"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core">

    <App>
        <Page showHeader="false" class="homePage">
            <content>
                <VBox class="homeShell">
                    <HBox class="heroBand" alignItems="Center" justifyContent="SpaceBetween">
                        <VBox class="heroCopy">
                            <ObjectStatus text="Order to Cash Suite" icon="sap-icon://business-suite" class="heroBadge"/>
                            <Title text="{/welcomeTitle}" level="H1" class="heroTitle"/>
                            <Text text="Your workspace for orders, customers, products, invoices, payments, reports, and analytics." class="heroSubtitle"/>
                            <HBox class="heroQuickStats" wrap="Wrap">
                                <ObjectStatus title="Today's Focus" text="Open orders" state="Information" icon="sap-icon://sales-order"/>
                                <ObjectStatus title="Next Step" text="Billing and collection" state="Success" icon="sap-icon://payment-approval"/>
                                <ObjectStatus title="Access" text="Secured with XSUAA" state="None" icon="sap-icon://locked"/>
                            </HBox>
                        </VBox>

                        <VBox class="heroPanel">
                            <Text text="Signed-in workspace" class="panelLabel"/>
                            <Title text="Move from order to cash with fewer clicks." level="H3" class="panelTitle"/>
                            <Text text="Choose a tile below to open the exact business area you need." class="panelText"/>
                        </VBox>
                    </HBox>

                    <VBox class="sectionBlock">
                        <HBox alignItems="End" justifyContent="SpaceBetween" class="sectionHeader">
                            <VBox>
                                <Title text="Business Areas" level="H2" class="sectionTitle"/>
                                <Text text="Jump directly into the work center you need." class="sectionText"/>
                            </VBox>
                        </HBox>

                        <l:Grid
                            defaultSpan="XL3 L4 M6 S12"
                            hSpacing="1"
                            vSpacing="1"
                            class="tileGrid">

                            <GenericTile
                                header="Orders"
                                subheader="Create, track, and manage sales orders"
                                frameType="TwoByOne"
                                class="navTile tileOrders"
                                press="onTilePress">
                                <customData>
                                    <core:CustomData key="target" value="orders"/>
                                </customData>
                                <TileContent>
                                    <NumericContent icon="sap-icon://sales-order" value="Open" withMargin="false"/>
                                </TileContent>
                            </GenericTile>

                            <GenericTile
                                header="Customers"
                                subheader="Customer master, credit, and account status"
                                frameType="TwoByOne"
                                class="navTile tileCustomers"
                                press="onTilePress">
                                <customData>
                                    <core:CustomData key="target" value="customers"/>
                                </customData>
                                <TileContent>
                                    <NumericContent icon="sap-icon://customer" value="Serve" withMargin="false"/>
                                </TileContent>
                            </GenericTile>

                            <GenericTile
                                header="Products"
                                subheader="Catalog, prices, categories, and stock"
                                frameType="TwoByOne"
                                class="navTile tileProducts"
                                press="onTilePress">
                                <customData>
                                    <core:CustomData key="target" value="products"/>
                                </customData>
                                <TileContent>
                                    <NumericContent icon="sap-icon://product" value="Stock" withMargin="false"/>
                                </TileContent>
                            </GenericTile>

                            <GenericTile
                                header="Order Items"
                                subheader="Line items, quantities, and product links"
                                frameType="TwoByOne"
                                class="navTile tileItems"
                                press="onTilePress">
                                <customData>
                                    <core:CustomData key="target" value="orderitems"/>
                                </customData>
                                <TileContent>
                                    <NumericContent icon="sap-icon://list" value="Lines" withMargin="false"/>
                                </TileContent>
                            </GenericTile>

                            <GenericTile
                                header="Approvals"
                                subheader="Review pending decisions and credit checks"
                                frameType="TwoByOne"
                                class="navTile tileApprovals"
                                press="onTilePress">
                                <customData>
                                    <core:CustomData key="target" value="approvals"/>
                                </customData>
                                <TileContent>
                                    <NumericContent icon="sap-icon://approvals" value="Review" withMargin="false"/>
                                </TileContent>
                            </GenericTile>

                            <GenericTile
                                header="Invoices"
                                subheader="Billing documents, due dates, and status"
                                frameType="TwoByOne"
                                class="navTile tileInvoices"
                                press="onTilePress">
                                <customData>
                                    <core:CustomData key="target" value="invoices"/>
                                </customData>
                                <TileContent>
                                    <NumericContent icon="sap-icon://document-text" value="Bill" withMargin="false"/>
                                </TileContent>
                            </GenericTile>

                            <GenericTile
                                header="Payments"
                                subheader="Collections, payment modes, and clearing"
                                frameType="TwoByOne"
                                class="navTile tilePayments"
                                press="onTilePress">
                                <customData>
                                    <core:CustomData key="target" value="payments"/>
                                </customData>
                                <TileContent>
                                    <NumericContent icon="sap-icon://payment-approval" value="Collect" withMargin="false"/>
                                </TileContent>
                            </GenericTile>

                            <GenericTile
                                header="Reports"
                                subheader="Operational summaries and business views"
                                frameType="TwoByOne"
                                class="navTile tileReports"
                                press="onTilePress">
                                <customData>
                                    <core:CustomData key="target" value="reports"/>
                                </customData>
                                <TileContent>
                                    <NumericContent icon="sap-icon://business-objects-experience" value="View" withMargin="false"/>
                                </TileContent>
                            </GenericTile>

                            <!-- <GenericTile
                                header="Analytics"
                                subheader="Explore performance and order insights"
                                frameType="TwoByOne"
                                class="navTile tileAnalytics"
                                press="onTilePress">
                                <customData>
                                    <core:CustomData key="target" value="analytics"/>
                                </customData>
                                <TileContent>
                                    <NumericContent icon="sap-icon://business-objects-mobile" value="Analyze" withMargin="false"/>
                                </TileContent>
                            </GenericTile> -->
                        </l:Grid>
                    </VBox>
                </VBox>
            </content>
        </Page>
    </App>
</mvc:View>
