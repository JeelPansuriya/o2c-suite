<mvc:View
    controllerName="o2c.home.controller.Home"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds">

<App>
<Page showHeader="false" class="pageBg">

<content>

    <!-- WELCOME HERO SECTION -->
    <VBox class="welcomeHero sapUiLargeMargin">
        <Title text="Welcome Back!" level="H1" class="welcomeTitle"/>
        <Text text="Manage your Order-to-Cash process seamlessly. Access all your business operations from here." class="welcomeSubtitle"/>
    </VBox>

    <!-- NAVIGATION CARDS GRID -->
    <l:Grid
        defaultSpan="XL2 L3 M6 S12"
        hSpacing="1"
        vSpacing="1"
        class="sapUiMediumMargin navCardsGrid">

        <Button
            text="Orders"
            icon="sap-icon://sales-order"
            press="onNavigate"
            class="navCard"
            type="Emphasized"
            width="100%">
            <customData>
                <core:CustomData key="target" value="orders"/>
            </customData>
        </Button>

        <Button
            text="Products"
            icon="sap-icon://product"
            press="onNavigate"
            class="navCard"
            type="Emphasized"
            width="100%">
            <customData>
                <core:CustomData key="target" value="products"/>
            </customData>
        </Button>

        <Button
            text="Customers"
            icon="sap-icon://customer"
            press="onNavigate"
            class="navCard"
            type="Emphasized"
            width="100%">
            <customData>
                <core:CustomData key="target" value="customers"/>
            </customData>
        </Button>

        <Button
            text="Invoices"
            icon="sap-icon://document-text"
            press="onNavigate"
            class="navCard"
            type="Emphasized"
            width="100%">
            <customData>
                <core:CustomData key="target" value="invoices"/>
            </customData>
        </Button>

        <Button
            text="Payments"
            icon="sap-icon://payment-approval"
            press="onNavigate"
            class="navCard"
            type="Emphasized"
            width="100%">
            <customData>
                <core:CustomData key="target" value="payments"/>
            </customData>
        </Button>

        <Button
            text="Reports"
            icon="sap-icon://bar-chart"
            press="onNavigate"
            class="navCard"
            type="Emphasized"
            width="100%">
            <customData>
                <core:CustomData key="target" value="reports"/>
            </customData>
        </Button>
        <Button
            text="Analytics"
            icon="sap-icon://bar-chart"
            press="onNavigate"
            class="navCard"
            type="Emphasized"
            width="100%">
            <customData>
                <core:CustomData key="target" value="analytics"/>
            </customData>
        </Button>

    </l:Grid>

    <!-- CHARTS GRID -->
    <l:Grid
        defaultSpan="XL6 L6 M12 S12"
        hSpacing="1"
        vSpacing="1"
        class="sapUiMediumMargin">

        <!-- SALES TREND -->
        <VBox class="chartCard">
            <Title text="Sales Trend"/>
            <viz:VizFrame
                vizType="line"
                width="100%"
                height="350px">

                <viz:dataset>
                    <viz.data:FlattenedDataset data="{/sales}">
                        <viz.data:dimensions>
                            <viz.data:DimensionDefinition name="Month" value="{month}"/>
                        </viz.data:dimensions>
                        <viz.data:measures>
                            <viz.data:MeasureDefinition name="Orders" value="{value}"/>
                        </viz.data:measures>
                    </viz.data:FlattenedDataset>
                </viz:dataset>

                <viz:feeds>
                    <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Orders"/>
                    <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Month"/>
                </viz:feeds>

            </viz:VizFrame>
        </VBox>

        <!-- ORDER STATUS -->
        <VBox class="chartCard">
            <Title text="Order Status"/>
            <viz:VizFrame
                vizType="donut"
                width="100%"
                height="350px">

                <viz:dataset>
                    <viz.data:FlattenedDataset data="{/status}">
                        <viz.data:dimensions>
                            <viz.data:DimensionDefinition name="Status" value="{status}"/>
                        </viz.data:dimensions>
                        <viz.data:measures>
                            <viz.data:MeasureDefinition name="Count" value="{count}"/>
                        </viz.data:measures>
                    </viz.data:FlattenedDataset>
                </viz:dataset>

                <viz:feeds>
                    <viz.feeds:FeedItem uid="size" type="Measure" values="Count"/>
                    <viz.feeds:FeedItem uid="color" type="Dimension" values="Status"/>
                </viz:feeds>

            </viz:VizFrame>
        </VBox>

    </l:Grid>

</content>
</Page>
</App>
</mvc:View>