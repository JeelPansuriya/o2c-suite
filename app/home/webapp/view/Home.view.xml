<mvc:View
    controllerName="o2c.home.controller.Home"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds">

<App>
<Page showHeader="false" class="pageBg">

<content>

    <!-- HEADER -->
    <VBox class="sapUiLargeMargin">
        <Title text="O2C Dashboard" level="H2"/>
        <Text text="Order-to-Cash Overview"/>
    </VBox>

    <!-- KPI GRID -->
    <l:Grid
        defaultSpan="XL2 L3 M6 S12"
        hSpacing="1"
        vSpacing="1"
        class="sapUiMediumMargin">

        <GenericTile header="Orders" press="onTilePress">
            <customData>
                <core:CustomData key="target" value="orders"/>
            </customData>
            <TileContent>
                <NumericContent value="{/kpi/orders}" icon="sap-icon://sales-order"/>
            </TileContent>
        </GenericTile>

        <GenericTile header="Products" press="onTilePress">
            <customData>
                <core:CustomData key="target" value="products"/>
            </customData>
            <TileContent>
                <NumericContent value="{/kpi/products}" icon="sap-icon://product"/>
            </TileContent>
        </GenericTile>

        <GenericTile header="Customers" press="onTilePress">
            <customData>
                <core:CustomData key="target" value="customers"/>
            </customData>
            <TileContent>
                <NumericContent value="{/kpi/customers}" icon="sap-icon://customer"/>
            </TileContent>
        </GenericTile>

        <GenericTile header="Invoices" press="onTilePress">
            <customData>
                <core:CustomData key="target" value="invoices"/>
            </customData>
            <TileContent>
                <NumericContent value="{/kpi/invoices}" icon="sap-icon://document-text"/>
            </TileContent>
        </GenericTile>

        <GenericTile header="Payments" press="onTilePress">
            <customData>
                <core:CustomData key="target" value="payments"/>
            </customData>
            <TileContent>
                <NumericContent value="{/kpi/payments}" icon="sap-icon://payment-approval"/>
            </TileContent>
        </GenericTile>

    </l:Grid>

    <!-- CHARTS GRID -->
    <l:Grid
        defaultSpan="XL6 L6 M12 S12"
        hSpacing="1"
        vSpacing="1"
        class="sapUiMediumMargin">

        <!-- SALES TREND -->
        <VBox class="chartCard">
            <Title text="Sales Trend"/>
            <viz:VizFrame
                vizType="line"
                width="100%"
                height="350px">

                <viz:dataset>
                    <viz.data:FlattenedDataset data="{/sales}">
                        <viz.data:dimensions>
                            <viz.data:DimensionDefinition name="Month" value="{month}"/>
                        </viz.data:dimensions>
                        <viz.data:measures>
                            <viz.data:MeasureDefinition name="Orders" value="{value}"/>
                        </viz.data:measures>
                    </viz.data:FlattenedDataset>
                </viz:dataset>

                <viz:feeds>
                    <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Orders"/>
                    <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Month"/>
                </viz:feeds>

            </viz:VizFrame>
        </VBox>

        <!-- ORDER STATUS -->
        <VBox class="chartCard">
            <Title text="Order Status"/>
            <viz:VizFrame
                vizType="donut"
                width="100%"
                height="350px">

                <viz:dataset>
                    <viz.data:FlattenedDataset data="{/status}">
                        <viz.data:dimensions>
                            <viz.data:DimensionDefinition name="Status" value="{status}"/>
                        </viz.data:dimensions>
                        <viz.data:measures>
                            <viz.data:MeasureDefinition name="Count" value="{count}"/>
                        </viz.data:measures>
                    </viz.data:FlattenedDataset>
                </viz:dataset>

                <viz:feeds>
                    <viz.feeds:FeedItem uid="size" type="Measure" values="Count"/>
                    <viz.feeds:FeedItem uid="color" type="Dimension" values="Status"/>
                </viz:feeds>

            </viz:VizFrame>
        </VBox>

    </l:Grid>

</content>
</Page>
</App>
</mvc:View>